@model Gestion_de_stock.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Index";
}
<style>
    .table {
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

        .table th, .table td {
            padding: 12px 15px;
            text-align: left;
        }

    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
    }
</style>
<div class="row" style="margin:30px 0px">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Products</h5>
                <p class="card-text">💼 @Model.TotalProducts</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5 class="card-title">Low Stock Products</h5>
                <p class="card-text">⚠️ @Model.LowStockCount</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Purshare</h5>
                <p class="card-text">💰 @Model.TotalPurchare DH</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Sales</h5>
                <p class="card-text">💰 @Model.TotalSales DH</p>
            </div>
        </div>
    </div>

</div>

<div class="row">
    <div class="col-md-6">
        <h2>Top 5 Best-Selling Products</h2>
        <table id="topSellingTable" class="table table-striped table-hover">
            <thead class="table-dark ">
                <tr style="cursor:pointer">
                    <th onclick="sortTable('topSellingTableBody',0)">Product ⬍</th>
                    <th onclick="sortTable('topSellingTableBody',1)">Category ⬍</th>
                    <th onclick="sortTable('topSellingTableBody',2)">Total Sold ⬍</th>
                    <th onclick="sortTable('topSellingTableBody',3)">Total Sales (Dh) ⬍</th>
                </tr>
            </thead>
            <tbody id="topSellingTableBody">
                @foreach (var item in Model.TopSellingProducts)
                {
                    <tr>
                        <td>@item.NomProduit</td>
                        <td>@item.NomCategorie</td>
                        <td>@item.Quantite</td>
                        <td>@item.TotalVente</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="col-md-6">
        <h2>Top 5 Most Purchased Products</h2>
        <table id="topPurchasedTable" class="table table-striped table-hover">
            <thead class="table-dark">
                <tr style="cursor:pointer">
                    <th onclick="sortTable('topPurchasedTableBody', 0)">Product ⬍</th>
                    <th onclick="sortTable('topPurchasedTableBody', 1)">Category ⬍</th>
                    <th onclick="sortTable('topPurchasedTableBody', 2)">Total Purchased ⬍</th>
                    <th onclick="sortTable('topPurchasedTableBody', 3)">Total Purchase (Dh) ⬍</th>
                </tr>
            </thead>
            <tbody id="topPurchasedTableBody">
                @foreach (var item in Model.TopPurchasedProducts)
                {
                    <tr>
                        <td>@item.NomProduit</td>
                        <td>@item.NomCategorie</td>
                        <td>@item.Quantite</td>
                        <td>@item.TotalVente</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>



<div class="row mt-4">
    <div class="col-12">
        <h2>Products Running Low on Stock</h2>
        <table id="lowStockTable" class="table table-striped table-hover">
            <thead class="table-dark">
                <tr style="cursor:pointer">
                    <th onclick="sortTable('lowStockTableBody', 0)">Product ⬍</th>
                    <th onclick="sortTable('lowStockTableBody', 1)">Description ⬍</th>
                    <th onclick="sortTable('lowStockTableBody', 2)">Category ⬍</th>
                    <th onclick="sortTable('lowStockTableBody', 3)">Purchase Price ⬍</th>
                    <th onclick="sortTable('lowStockTableBody', 4)">Selling Price ⬍</th>
                    <th onclick="sortTable('lowStockTableBody', 5)">Supplier ⬍</th>
                    <th onclick="sortTable('lowStockTableBody', 6)">Stock Quantity ⬍</th>
                </tr>
            </thead>
            <tbody id="lowStockTableBody">
                @foreach (var item in Model.LowStockProducts)
                {
                    <tr>
                        <td>@item.Nom</td>
                        <td>@item.Description</td>
                        <td>@item.Categorie.Nom</td>
                        <td>@item.PrixAchat</td>
                        <td>@item.PrixVente</td>
                        <td>@item.Fournisseur.Telephone</td>
                        <td>@item.QuantiteStock</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

        <script>
            $(document).ready(function () {
                $('#topSellingTable').DataTable({
                    "paging": false,  // Disable pagination (optional)
                    "info": false,    // Disable info text (optional)
                    "ordering": true  // Enable sorting
                });
            });
        </script>

