@model Gestion_de_stock.ViewModels.FournisseurViewModel

@{
    ViewData["Title"] = "Fournisseur - Management";
}

<div class="row my-4" style="justify-content:center">
    <div class="col-md-4">
        <h4 class="m-3" style="align-items:center">Add New Fournisseur</h4>
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                @*<label asp-for="@Model.NewFournisseur.Nom" class="control-label"></label>*@
                <input asp-for="@Model.NewFournisseur.Nom" required placeholder="Fournisseur Nom" class="form-control mt-3" maxlength="30" minlength="3" />
                <span asp-validation-for="@Model.NewFournisseur.Nom" class="text-danger"></span>
                @if (ViewBag.errorFourniName != null)
                {
                    <label class="text-danger m-2"> @ViewBag.errorFourniName</label>
                }
            </div>
            <div class="form-group">
                @*<label asp-for="@Model.NewFournisseur.Telephone" class="control-label"></label>*@
                <input asp-for="@Model.NewFournisseur.Telephone" required placeholder="Fournisseur Telephone" maxlength="10" minlength="10" class="form-control mt-3" type="number" />
                <span asp-validation-for="@Model.NewFournisseur.Telephone" class="text-danger"></span>
            </div>
            <div class="form-group">
                @*<label asp-for="@Model.NewFournisseur.Adresse" class="control-label"></label>*@
                <input asp-for="@Model.NewFournisseur.Adresse" required placeholder="Fournisseur Adresse" maxlength="80" minlength="4" class="form-control mt-3" />
                <span asp-validation-for="@Model.NewFournisseur.Adresse" class="text-danger"></span>
            </div>
            <div class="form-group" style="text-align:center">
                <input type="submit" value="Create" class="btn btn-primary my-3" />
            </div>
        </form>
    </div>
</div>

<h3 style="text-align:center" class="m-3">Fournisseur List</h3>
@if (Model.Fournisseurs == null || !Model.Fournisseurs.Any())
{
    <centre>
        <h2 style="color:yellow;">Empty Fournisseur</h2>
    </centre>
    
}
else
{
    <!-- Search Input -->
<center>
    <input type="text" id="searchInput" class="form-control mb-3" placeholder="Search by name..." onkeyup="filterTable()" style="width:40%;">

</center>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Fournisseurs.First().Nom)</th>
                <th>Telephone</th>
                <th>Adresse</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="fournisseurTableBody">
            @foreach (var item in Model.Fournisseurs)
            {
                <tr>
                    <form asp-action="Edit" method="post">
                    <td>
                        <input type="hidden" name="Id" value="@item.Id" />
                        <input type="text" name="Nom" class="form-control" value="@item.Nom" required />
                    </td>
                    <td>
                        <input type="tel" name="Telephone" class="form-control" value="@item.Telephone" required />
                    </td>
                    <td>
                        <input type="text" name="Adresse" class="form-control" value="@item.Adresse" required />
                    </td>
                    <td style="display:flex; justify-content:space-evenly">
                        <button type="submit" class="btn btn-success btn-sm">Edit</button>
                        <a asp-action="Delete" asp-route-id="@item.Id" onclick="confirmDelete()" style="text-decoration:underline; color:red">Delete</a>
                    </td>
                    </form>
                </tr>
            }
        </tbody>
    </table>

}
@section Scripts {
    <partial name="_Validation" />
}

<script>
    function confermDelete() {
        if (confirm('Delete This Fournisseur ?')) { return true; }
        else { event.stopPropagation(); event.preventDefault(); };
    }
</script>
<script>
    function filterTable() {
        var input = document.getElementById("searchInput");
        var filter = input.value.toLowerCase();
        var rows = document.querySelectorAll("#fournisseurTableBody tr");

        rows.forEach(row => {
            var nameCell = row.querySelector("td input[name='Nom']");
            if (nameCell) {
                var nameValue = nameCell.value.toLowerCase();
                row.style.display = nameValue.includes(filter) ? "" : "none";
            }
        });
    }
</script>

