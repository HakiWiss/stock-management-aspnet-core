@model Gestion_de_stock.ViewModels.CategorieViewModel

@{
    ViewData["Title"] = "Index";
}

<div class="row my-4" style="justify-content:center">
    <div class="col-md-4">
        <h4 class="m-3" style="align-items:center">Add New Category</h4>
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                @*<label asp-for="@Model.NewCategorie.Nom" class="control-label"></label>*@
                <input asp-for="@Model.NewCategorie.Nom" placeholder="Category Name" required min="3" class="form-control mt-3" />
                <span asp-validation-for="@Model.NewCategorie.Nom" class="text-danger"></span>
                @if (ViewBag.errorCategoryName != null)
                {
                    <label class="text-danger m-2"> @ViewBag.errorCategoryName</label>
                }
            </div>
            
                <div class="form-group" style="text-align:center;">
                    <input type="submit" value="Create" class="btn btn-primary my-2" />
                </div>
            
            
        </form>
    </div>
</div>

<h3 style="text-align:center" class="m-3">Category List</h3>
@if (Model.Categories == null || !Model.Categories.Any())
{
    <centre>
        <h2 style="color:yellow;">Empty Category</h2>
    </centre>
    
}
else
{
    <table class="table table-striped table-hover" style="width:70%; margin:0 auto;">
        <thead class="table-dark ">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Categories.First().Nom)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Categories)
            {
            <tr>
                <form asp-action="Edit" method="post">
                <td>
                    <!-- Form to Update Each Category -->
                    <input type="hidden" name="Id" value="@item.Id" />
                    <input type="text" name="Nom" class="form-control" value="@item.Nom" />
                </td>
                <td style="display:flex; justify-content:space-evenly">
                    <button type="submit" class="btn btn-success btn-sm">Save</button>
                    <a asp-action="Delete" asp-route-id="@item.Id" onclick="confermDelete()" style="text-decoration:none; color:red; text-decoration:underline">Delete</a>
                </td>
                </form>
            </tr>
            }
        </tbody>
    </table>
}
@section Scripts {
    <partial name="_Validation" />
}

<script>
    function confermDelete() {
        if (confirm('Delete This Category ?')) { return true; }
        else { event.stopPropagation(); event.preventDefault(); };
    }
</script>

